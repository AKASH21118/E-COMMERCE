# Vite frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# Backend API URL
# Development: proxied via Vite dev server (leave as /api or point to local backend)
# Production: set to your Render backend URL e.g. https://your-app.onrender.com/api
VITE_API_BASE_URL=http://localhost:4000/api
