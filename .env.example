# Vite frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# Backend API URL (default proxies to /api via Vite dev server)
VITE_API_BASE_URL=http://localhost:4000/api

# Google OAuth Client ID
# Get this from https://console.cloud.google.com/ → APIs & Services → Credentials
# Must match the GOOGLE_CLIENT_ID set in backend/.env
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
