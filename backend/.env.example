PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL Database (Neon)
# Get your connection string from https://neon.tech → Project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars

# Payments (Razorpay)
PAYMENT_PROVIDER=razorpay
PAYMENT_CURRENCY=INR
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS (Fast2SMS)
SMS_PROVIDER=fast2sms
FAST2SMS_API_KEY=your_fast2sms_api_key
